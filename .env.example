# ============================================================
# SilverShade — root environment file for Docker Compose
# Copy this file to .env and fill in all the values below.
#
#   Windows:  Copy-Item .env.example .env
#   Linux:    cp .env.example .env
#
# Then run:   docker compose up --build -d
#
# ── KEY NAMING RULES ────────────────────────────────────────
# All four services (API, Website, DiscordBot, FivemDummy) pull from this
# single file via docker-compose.yml. The Website proxy needs no secrets of
# its own — it just forwards every /api/* request to the API container.
# ============================================================


# ── Shared secrets (used by API + both bots) ────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_32_plus_char_random_secret
SERVICE_API_KEY=replace_with_strong_api_key


# ── API ─────────────────────────────────────────────────────
APP_NAME=SilverShade API
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
# Name of the httpOnly cookie that holds the JWT.  Change only if you have
# a specific reason — all services must agree on the same name.
AUTH_COOKIE_NAME=silvershade_access_token
# Set to true once HTTPS is live (requires a reverse proxy / SSL cert)
AUTH_COOKIE_SECURE=false

MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=silvershade

ALLOWED_ORIGINS=http://localhost:8080
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Optional: Redis URL for distributed rate limiting (multiple API instances).
# Leave blank to use the in-process sliding-window fallback (fine for single instance).
# REDIS_URL=redis://localhost:6379/0

# Optional: Discord webhook URL used by admin simulation endpoints
DISCORD_TEST_WEBHOOK_URL=

# Optional: HMAC-SHA256 key for signing outbound webhook payloads (§1.7).
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
# Leave blank to send webhooks without a signature header.
WEBHOOK_SECRET=


# ── Stripe Payment Integration (§3) ─────────────────────────
# Sign up free at stripe.com → Developers → API keys → test mode
# sk_test_... is the secret key (server-side only, never expose to frontend)
# pk_test_... is the publishable key (can be shared with frontend if needed)
# whsec_... is the webhook endpoint signing secret (Stripe Dashboard → Webhooks)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me


# ── Discord Bot ─────────────────────────────────────────────
# DISCORD_TOKEN     — Bot token from discord.com/developers/applications
# DISCORD_CLIENT_ID — Application ID (OAuth2 → General Information → Application ID)
# DISCORD_GUILD_ID  — Right-click your server → Copy Server ID
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_GUILD_ID=your_discord_server_id
COMMAND_PREFIX=!
ADMIN_ROLE_NAME=Admin
# Comma-separated Discord channel IDs where the bot posts log messages.
# Example: LOG_CHANNEL_IDS=123456789012345678,987654321098765432
LOG_CHANNEL_IDS=
# JSON map of backend role names → Discord role IDs.
# Example: BACKEND_ROLE_MAP={"admin":"123456789012345678","vip":"987654321098765432"}
BACKEND_ROLE_MAP={}
POLL_INTERVAL_MS=5000


# ── FiveM Dummy Server ───────────────────────────────────────
# A signed JWT with role=admin — only needed for --simulate-* CLI flags.
# Leave blank if you never use --simulate-rewards / --simulate-actions.
SILVERSHADE_ADMIN_TOKEN=
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=500
# Path (relative to FivemDummy/) where the server writes its log file.
LOG_FILE_PATH=logs/server.log
