DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_GUILD_ID=your_discord_server_id
COMMAND_PREFIX=!

SILVERSHADE_API=http://127.0.0.1:8000
SILVERSHADE_API_KEY=replace_with_service_key
SILVERSHADE_ADMIN_TOKEN=replace_with_admin_jwt_for_simulation

# Comma-separated Discord channel IDs used for logs.
LOG_CHANNEL_IDS=123456789012345678,987654321098765432

# Name of the Discord role allowed to run admin commands.
ADMIN_ROLE_NAME=Admin

# Polling interval in milliseconds for backend sync.
POLL_INTERVAL_MS=5000

# Optional: map backend roles to Discord role IDs (JSON string)
# Example: {"admin":"123456789012345678","vip":"987654321098765432"}
BACKEND_ROLE_MAP={}
