APP_NAME=SilverShade API

# JWT — use a random string of at least 32 characters
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_32_plus_char_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
# Name of the httpOnly cookie that holds the JWT. Default is fine for most setups.
AUTH_COOKIE_NAME=silvershade_access_token
# Set True in production (requires HTTPS)
AUTH_COOKIE_SECURE=False

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=silvershade

# Service-to-service API key (used by FivemDummy and DiscordBot)
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
SERVICE_API_KEY=replace_with_strong_api_key

# CORS: comma-separated list of origins allowed to call this API.
# In dev, this is the Website frontend server. In production, your domain.
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Optional: Redis URL for distributed rate limiting across multiple instances.
# If not set, an in-process dict is used (resets on restart, fine for single-instance).
# REDIS_URL=redis://localhost:6379/0

# Optional: Discord webhook URL for admin simulate-discord-pickup endpoint
DISCORD_TEST_WEBHOOK_URL=

# Optional: HMAC-SHA256 key for signing outbound webhook payloads (§1.7).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Leave blank to send webhooks without a signature header.
WEBHOOK_SECRET=

# ── Stripe Payment Integration (§3) ─────────────────────────────────────────
# Sign up free at stripe.com → Developers → API keys → switch to Test mode.
# sk_test_... is the secret key — never expose this to the browser.
# pk_test_... is the publishable key — safe to embed in frontend JS if needed.
# whsec_... is the webhook signing secret from Stripe Dashboard → Webhooks.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
